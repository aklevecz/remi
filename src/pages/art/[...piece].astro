---
import { getDb } from "../../lib/db";
import Layout from "../../layouts/Layout.astro";

const { piece } = Astro.params;
const db = getDb(Astro.locals.runtime.env.DB);
const paintings = piece ? await db.getPainting(piece) : [];
const painting = paintings[0];
if (!painting) {
  return Astro.redirect("/404");
}

const description = `${painting.title}
${painting.material}
${painting.year}`;
const imageSrc = `https://storage.remifrogo.art/${painting.key}`;
---

<Layout title={painting.title} seo={{ title: painting.title, description, image: imageSrc }}>
  <img src={imageSrc} />
  <div class="details">
    <h1>{painting.title}</h1>
    <div>{painting.material}</div>
    <div>{painting.dimensions}</div>
    <div>{painting.year}</div>
  </div>
</Layout>
<style>
  img {
    width: 90%;
    max-width: 600px;
    /* height:100%; */
    display: block;
    margin: auto;
  }
  h1 {
    /* position:absolute;
        top:10px;
        left:10px; */
    margin: 0px;
    font-size: 1.5rem;
    font-weight: 600;
  }
  .details {
    margin:2rem;
    text-align: center;
  }
</style>
